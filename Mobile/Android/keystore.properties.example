# Android release signing credentials — TEMPLATE.
# Copy this file to `keystore.properties` (which is gitignored) and fill in the real
# values from the upload keystore you create for Snakeball. Never commit the real file
# or the .jks; back them up separately (e.g. a password manager).
#
#   storeFile     — path to your .jks, relative to Mobile/Android/
#   storePassword — keystore password
#   keyAlias      — alias name you gave the key (Android Studio default: "key0")
#   keyPassword   — key password (often the same as storePassword)

storeFile=snakeball.jks
storePassword=CHANGE_ME
keyAlias=key0
keyPassword=CHANGE_ME

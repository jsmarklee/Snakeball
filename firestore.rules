rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Leaderboard: 클라이언트는 읽기만 (top-N 직접 쿼리). 쓰기는 Cloud Function(Admin SDK)만.
    // leaderboard_global, leaderboard_weekly_{YYYYWW} 등 leaderboard_ 로 시작하는 모든 컬렉션.
    match /{col}/{doc} {
      allow read: if col.matches('^leaderboard_.*$');
      allow write: if false; // 클라이언트 직접 쓰기 차단 — submitScore/setName 함수 사용
    }

    // 게임 세션 (안티치트 앵커): 함수 전용. 클라이언트 접근 전면 차단.
    match /game_sessions/{token} {
      allow read, write: if false;
    }

    // 서버 전용 config: 클라이언트 접근 없음.
    match /config/{docId} {
      allow read, write: if false;
    }

    // IAP 멱등성 원장 (전역 {platform}:{txId}): 함수(Admin SDK) 전용. 클라이언트 차단.
    match /processed_transactions/{id} {
      allow read, write: if false;
    }

    // 유저 데이터: 본인만 읽기. 화이트리스트 필드만 생성/수정 가능.
    // ⚠️ name/bestScore는 화이트리스트에서 제외 — 둘 다 서버 권위 필드다 (플레이북 §5).
    //   - name: setName 함수가 blocklist+길이로 모더레이션한다. 룰로 직접 쓰게 두면
    //     악성 클라가 updateDoc({name:'<욕설>'})로 모더레이션을 우회하고, submitScore가
    //     그 값을 리더보드로 전파한다(글로벌 #1 욕설 → 스토어 리젝). Admin SDK 전용 쓰기.
    //   - bestScore: submitScore가 세션 검증 후에만 갱신. 클라 쓰기 불필요.
    // (서버는 Admin SDK라 룰을 우회하므로 name/bestScore 서버 갱신은 영향 없음.)
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'stableId', 'createdAt', 'lastSeenAt'
        ]);

      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'stableId', 'createdAt', 'lastSeenAt'
        ]);

      // 삭제 차단.
      allow delete: if false;
    }
  }
}
